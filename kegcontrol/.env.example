# KegControl — variáveis de ambiente (copie para .env e preencha)

# Banco: Postgres do Supabase (pooler + schema dedicado kegcontrol)
DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-1-us-east-2.pooler.supabase.com:5432/postgres?schema=kegcontrol"

# Segredo de sessão + chave de criptografia (AES-GCM) das credenciais do WhatsApp.
# Use o MESMO valor em todos os ambientes que compartilham o banco.
AUTH_SECRET="troque-por-um-segredo-forte-e-unico"

# IA do agente (Gemini). Sem ela, o agente roda em modo simulado.
GEMINI_API_KEY=""

# URL pública do app — necessária para o WhatsApp RECEBER mensagens (webhook).
APP_URL="http://localhost:3020"

# WhatsApp via Evolution API (self-hosted, WhatsApp Web). A instância é criada
# por empresa automaticamente (kegcontrol-<companyId>).
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""

# Números (separados por vírgula) que o agente atende. Vazio = atende todos.
WHATSAPP_ALLOWED_NUMBERS=""
