generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  phone         String?        @unique // E.164 sem "+", ex.: 5511999998888 — identidade dos usuários via WhatsApp
  name          String?
  image         String?
  timezone      String         @default("America/Sao_Paulo")
  workdayStart  Int            @default(8)
  workdayEnd    Int            @default(19)
  defaultDurMin Int            @default(60)
  createdAt     DateTime       @default(now())
  integrations  Integration[]
  conversations Conversation[]
  events        Event[]
  actionLogs    ActionLog[]
  company       Company?
}

// Integração externa (Google). Pertence a UM dono: usuário (modo pessoal)
// OU empresa (modo B2B) — nunca ambos.
model Integration {
  id           String    @id @default(cuid())
  userId       String?
  companyId    String?
  provider     String // "google"
  accessToken  String // criptografado (AES-256-GCM)
  refreshToken String? // criptografado
  expiresAt    DateTime?
  scope        String?
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@unique([companyId, provider])
}

// ─── Modo Empresa (B2B) — cada empresa é um tenant totalmente isolado ───

model Company {
  id                String                @id @default(cuid())
  ownerUserId       String                @unique
  name              String
  agentName         String                @default("Ana")
  welcomeMessage    String?
  timezone          String                @default("America/Sao_Paulo")
  workdayStart      Int                   @default(8)
  workdayEnd        Int                   @default(18)
  defaultDurMin     Int                   @default(60)
  evolutionInstance String                @unique // instância WhatsApp própria da empresa
  createdAt         DateTime              @default(now())
  owner             User                  @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  services          Service[]
  clients           Client[]
  appointments      Appointment[]
  conversations     CompanyConversation[]
  integrations      Integration[]
}

model Service {
  id           String        @id @default(cuid())
  companyId    String
  name         String
  durationMin  Int
  description  String?
  price        Float?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([companyId])
}

// Cliente final da empresa (quem manda mensagem no WhatsApp dela) — base do CRM futuro
model Client {
  id           String        @id @default(cuid())
  companyId    String
  phone        String // E.164 sem "+"
  name         String?
  createdAt    DateTime      @default(now())
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([companyId, phone])
}

model Appointment {
  id        String   @id @default(cuid())
  companyId String
  clientId  String
  serviceId String?
  title     String // "Nome do cliente - Serviço"
  startsAt  DateTime
  endsAt    DateTime
  notes     String?
  googleId  String? // id do evento espelhado no Google Agenda da empresa
  status    String   @default("confirmed") // confirmed | canceled
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([companyId, startsAt])
}

// Conversa do atendente virtual com um cliente (histórico curto em JSON)
model CompanyConversation {
  id          String   @id @default(cuid())
  companyId   String
  clientPhone String
  history     String   @default("[]") // [{role:"user"|"model", text}]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, clientPhone])
}

model Conversation {
  id            String    @id @default(cuid())
  userId        String
  pendingAction String? // JSON de ação aguardando confirmação do usuário
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String // "user" | "assistant"
  content        String
  intent         String? // tipo da intenção detectada (auditoria)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// Agenda local (modo demo) + espelho dos eventos criados pelo app no Google
model Event {
  id          String   @id @default(cuid())
  userId      String
  title       String
  startsAt    DateTime
  endsAt      DateTime
  location    String?
  description String?
  source      String   @default("local") // "local" | "google"
  googleId    String?
  seriesId    String? // agrupa ocorrências de eventos recorrentes
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsAt])
}

model ActionLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  payload   String
  result    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Config de nível de aplicação (chave/valor). Hoje guarda os dados do servidor
// Evolution API definidos pela aba Conectar; a apikey fica criptografada no value.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
