# Obrigatório em produção — assina sessões e deriva a chave de criptografia dos tokens
AUTH_SECRET=troque-por-um-segredo-forte

# URL pública do app (usada no callback OAuth)
APP_URL=http://localhost:3050

# IA de resposta/intenção. Prioridade: Gemini > Claude > parser local (modo demo).
# Gemini (em uso atualmente)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Claude (alternativa)
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# Transcrição de voz (Groq Whisper) — sem a chave o botão de áudio pede para digitar
GROQ_API_KEY=

# Google OAuth + Calendar — sem as chaves o login vira "modo demonstração" com agenda local
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WhatsApp via Evolution API (self-hosted, não-oficial) — ver docs/WHATSAPP.md
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
WHATSAPP_WEBHOOK_TOKEN=

# Restringe quem o agente responde no WhatsApp (números separados por vírgula,
# com ou sem DDI 55 — tanto faz). Vazio = atende qualquer número.
WHATSAPP_ALLOWED_NUMBERS=
