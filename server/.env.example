# ── Obrigatórias ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Instagram (Apify + cookies de sessão) ─────────────────────────────────────
APIFY_API_KEY=apify_api_...

# Cookies da sua sessão Instagram (para scraping autenticado de contas restritas)
# Obter em: DevTools → Application → Cookies → instagram.com
INSTAGRAM_SESSION_ID=
INSTAGRAM_CSRF_TOKEN=
INSTAGRAM_DS_USER_ID=

# ── Opcionais ─────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=29vD33N1CtxCmqQRPOHJ

# Vault do Obsidian para sync de notas
# ATENÇÃO: funciona apenas em máquina local com Obsidian instalado.
# Na Hostinger (Linux), deixe vazio ou remova esta linha — o servidor ignora automaticamente.
# Exemplo local Windows: C:\Users\SeuNome\Documents\Obsidian Vault
# Exemplo local Mac/Linux: /home/usuario/vault
OBSIDIAN_VAULT_PATH=

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
