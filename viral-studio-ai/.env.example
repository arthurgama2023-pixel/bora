# === IA (Diretor Criativo) — sem nenhuma chave abaixo o app roda em MODO MOCK ===

# Provedor: "claude" ou "gemini". Se vazio, detecta automaticamente pela chave
# presente (ANTHROPIC_API_KEY tem prioridade se as duas estiverem definidas).
AI_PROVIDER=

# --- Opção A: Claude (padrão) ---
ANTHROPIC_API_KEY=
VIRAL_STUDIO_MODEL=claude-opus-4-8

# --- Opção B: Gemini ---
GEMINI_API_KEY=
VIRAL_STUDIO_GEMINI_MODEL=gemini-2.5-pro

# Força modo mock mesmo com chave configurada (útil para testes sem custo)
VIRAL_STUDIO_FORCE_MOCK=

# === Transcrição (Whisper) — usa o primeiro disponível ===
# Groq: mais barato e rápido (whisper-large-v3-turbo)
GROQ_API_KEY=
# OpenAI: fallback (whisper-1)
OPENAI_API_KEY=

# === FFmpeg ===
# Caminho customizado (padrão: usa o ffmpeg/ffprobe do PATH)
FFMPEG_PATH=
FFPROBE_PATH=

# === AUTENTICAÇÃO ===
# OBRIGATÓRIO EM PRODUÇÃO: segredo para assinar os cookies de sessão. Sem ele,
# um segredo aleatório é gravado em storage/.auth-secret — o que quebra sessões
# se o disco for efêmero (Render sem disco persistente) ou se houver >1 instância.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VIRAL_STUDIO_AUTH_SECRET=
# Duração da sessão em dias (padrão 30)
VIRAL_STUDIO_SESSION_DAYS=30
# Trava de beta fechado: se definido, só quem tem o código consegue se cadastrar.
# Deixe vazio para cadastro aberto.
VIRAL_STUDIO_INVITE_CODE=

# === E-MAIL (reset de senha) ===
# Sem RESEND_API_KEY, o link de reset é apenas logado no servidor (dev).
RESEND_API_KEY=
EMAIL_FROM=Viral Studio <onboarding@resend.dev>

# === CAPACIDADE / BACKPRESSURE ===
# Renders simultâneos (FFmpeg é pesado; suba com cautela conforme os núcleos)
VIRAL_STUDIO_CONCURRENCY=1
# Teto da fila antes de recusar novos jobs com 503
VIRAL_STUDIO_MAX_QUEUE=25
# Tamanho máx. de upload em MB (padrão 4096 = 4GB)
VIRAL_STUDIO_MAX_UPLOAD_MB=4096
# TTL de uploads temporários órfãos, em ms (padrão 6h)
VIRAL_STUDIO_TMP_TTL_MS=21600000
# Timeouts de chamadas externas, em ms
VIRAL_STUDIO_AI_TIMEOUT_MS=180000
VIRAL_STUDIO_TRANSCRIBE_TIMEOUT_MS=300000
